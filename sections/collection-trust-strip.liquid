{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .collection-trust-strip {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    border-top: 1px solid rgba(204, 164, 59, 0.2);
    border-bottom: 1px solid rgba(204, 164, 59, 0.2);
    position: relative;
    z-index: 2;
  }

  .collection-trust-strip__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    align-items: stretch;
  }

  @media screen and (min-width: 750px) {
    .collection-trust-strip__grid {
      grid-template-columns: repeat({{ section.blocks.size | default: 4 }}, 1fr);
      gap: 2rem;
    }
  }

  .collection-trust-strip__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1.2rem;
    background: #ffffff;
    border: 1px solid rgba(204, 164, 59, 0.25);
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
    transition: transform 0.3s cubic-bezier(0.165, 0.84, 0.44, 1), border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .collection-trust-strip__card:hover {
    transform: translateY(-4px);
    border-color: #cca43b;
    box-shadow: 0 10px 25px rgba(204, 164, 59, 0.15);
  }

  .collection-trust-strip__icon-wrap {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    color: #cca43b;
    background: rgba(204, 164, 59, 0.08);
    border-radius: 50%;
    padding: 10px;
  }

  .collection-trust-strip__icon-wrap svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
  }

  .collection-trust-strip__title {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 600;
    margin: 0 0 0.4rem 0;
    color: #121212;
    line-height: 1.3;
  }

  .collection-trust-strip__desc {
    font-size: 1.2rem;
    line-height: 1.4;
    color: #555555;
    margin: 0;
  }
{%- endstyle -%}

<div class="collection-trust-strip section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="center" style="margin-bottom: 2.5rem;">
        <h2 style="font-family: 'Playfair Display', serif; font-weight: 600; font-size: 2.2rem; color: #121212; margin: 0;">
          {{ section.settings.heading }}
        </h2>
      </div>
    {%- endif -%}

    <div class="collection-trust-strip__grid">
      {%- for block in section.blocks -%}
        <div class="collection-trust-strip__card" {{ block.shopify_attributes }}>
          <div class="collection-trust-strip__icon-wrap">
            {%- case block.settings.icon -%}
              {%- when 'alcohol_free' -%}
                <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18m0-18C8.5 3 6 5.5 6 9c0 3.5 3 7 6 12 3-5 6-8.5 6-12 0-3.5-2.5-6-6-6z"/></svg>
              {%- when 'clock' -%}
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 7v5l3 3"/></svg>
              {%- when 'truck' -%}
                <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.25v11.25m0-11.25h-4.5m4.5 0v3.75m-4.5-3.75h-3.75M4.5 6.75h3.75"/></svg>
              {%- when 'star' -%}
                <svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            {%- endcase -%}
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="collection-trust-strip__title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.desc != blank -%}
            <p class="collection-trust-strip__desc">{{ block.settings.desc }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection Trust Strip",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading (Optional)",
      "default": "Why Choose Mahekh Fragrances"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#faf8f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32,
      "label": "Padding Bottom"
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "alcohol_free", "label": "Drop (100% Pure / Alcohol Free)" },
            { "value": "clock", "label": "Clock (24h Long Lasting)" },
            { "value": "truck", "label": "Truck (Free Shipping & COD)" },
            { "value": "star", "label": "Star (4.9 Rating)" },
            { "value": "shield", "label": "Shield (Guaranteed Quality)" }
          ],
          "default": "alcohol_free"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100% Alcohol-Free"
        },
        {
          "type": "text",
          "id": "desc",
          "label": "Short Description",
          "default": "Pure concentrated oil, gentle on skin."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Trust Strip",
      "blocks": [
        {
          "type": "trust_badge",
          "settings": {
            "icon": "alcohol_free",
            "title": "100% Alcohol-Free",
            "desc": "Pure concentrated perfume oil, skin safe."
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "icon": "clock",
            "title": "24+ Hours Lasting",
            "desc": "Rich projection that lasts all day long."
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "icon": "truck",
            "title": "Free Delivery & COD",
            "desc": "Pay on delivery with express shipping."
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "icon": "star",
            "title": "10,000+ Happy Users",
            "desc": "Rated 4.9/5 by fragrance lovers."
          }
        }
      ]
    }
  ]
}
{% endschema %}
