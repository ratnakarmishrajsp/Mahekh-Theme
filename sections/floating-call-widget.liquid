{%- style -%}
  .left-call-widget {
    position: fixed;
    left: 18px;
    bottom: 90px; /* Positioned above mobile sticky buy bar */
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    font-family: inherit;
    transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  /* Team Support Badge Mockup */
  .left-call-widget__team-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #ffffff;
    border: 1px solid rgba(204, 164, 59, 0.35);
    padding: 6px 14px 6px 8px;
    border-radius: 30px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    font-size: 1.15rem;
    font-weight: 600;
    color: #121212;
  }

  .left-call-widget__team-avatars {
    position: relative;
    display: flex;
    align-items: center;
  }

  .left-call-widget__avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid #ffffff;
    object-fit: cover;
    background: #f5eedc;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
  }

  .left-call-widget__online-dot {
    position: absolute;
    bottom: 0;
    right: -2px;
    width: 9px;
    height: 9px;
    background: #10b981;
    border: 2px solid #ffffff;
    border-radius: 50%;
    animation: pulseDot 2s infinite;
  }

  @keyframes pulseDot {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
  }

  /* Call Action Button */
  .left-call-widget__btn {
    display: flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(135deg, #10b981 0%, #047857 100%);
    color: #ffffff !important;
    text-decoration: none !important;
    padding: 10px 18px;
    border-radius: 30px;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    box-shadow: 0 8px 25px rgba(16, 185, 129, 0.35);
    transition: all 0.3s ease;
  }

  .left-call-widget__btn:hover {
    transform: translateY(-2px) scale(1.03);
    box-shadow: 0 12px 30px rgba(16, 185, 129, 0.45);
    color: #ffffff !important;
  }

  .left-call-widget__icon {
    width: 18px;
    height: 18px;
    fill: #ffffff;
  }

  @media screen and (max-width: 749px) {
    .left-call-widget {
      left: 12px;
      bottom: 82px; /* Positioned right above mobile sticky buy bar */
    }
    .left-call-widget__team-badge {
      padding: 5px 12px 5px 6px;
      font-size: 1.05rem;
    }
    .left-call-widget__btn {
      padding: 9px 15px;
      font-size: 1.2rem;
    }
  }
{%- endstyle -%}

{%- unless section.settings.enable_call_widget == false -%}
  <div class="left-call-widget" id="LeftCallWidget-{{ section.id }}">
    <!-- Support Team Mockup Badge -->
    <div class="left-call-widget__team-badge">
      <div class="left-call-widget__team-avatars">
        <div class="left-call-widget__avatar" aria-label="Support Team Representative">🎧</div>
        <span class="left-call-widget__online-dot" aria-label="Online"></span>
      </div>
      <span>{{ section.settings.badge_text | default: "Mahekh Support Team" }}</span>
    </div>

    <!-- Call Button -->
    <a href="tel:{{ section.settings.phone_number | default: '919321868526' }}" class="left-call-widget__btn" aria-label="Call Mahekh Support Team">
      <svg class="left-call-widget__icon" viewBox="0 0 24 24" width="18" height="18">
        <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
      </svg>
      <span>{{ section.settings.button_text | default: "Call Now" }}</span>
    </a>
  </div>
{%- endunless -%}

{% schema %}
{
  "name": "Left Call Widget",
  "tag": "section",
  "class": "section-left-call-widget",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_call_widget",
      "label": "Enable Sticky Left Call Widget",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Support Team Badge Text",
      "default": "Mahekh Support Team"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Call Button Text",
      "default": "Call 93218-68526"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number for Call",
      "default": "919321868526"
    }
  ],
  "presets": [
    {
      "name": "Left Call Widget"
    }
  ]
}
{% endschema %}
