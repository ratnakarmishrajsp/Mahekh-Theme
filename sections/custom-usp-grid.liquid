{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-usp-grid {
    text-align: center;
  }

  .custom-usp-grid__wrapper {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media screen and (min-width: 750px) {
    .custom-usp-grid__wrapper {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: 3rem;
    }
  }

  .custom-usp-grid__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2.5rem 1.5rem;
    border-radius: 8px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    background: transparent;
  }

  .custom-usp-grid__item:hover {
    transform: translateY(-5px);
  }

  .custom-usp-grid__icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    width: 60px;
    height: 60px;
    color: rgb(var(--color-foreground));
  }

  .custom-usp-grid__icon-wrapper svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .custom-usp-grid__icon-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .custom-usp-grid__title {
    margin: 0 0 1rem 0;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .custom-usp-grid__text {
    margin: 0;
    line-height: 1.6;
    opacity: 0.85;
    font-size: 1.4rem;
  }

  /* Optional border styling for premium feel */
  .custom-usp-grid--borders .custom-usp-grid__item {
    border: 1px solid rgba(var(--color-foreground), 0.08);
  }
  .custom-usp-grid--borders .custom-usp-grid__item:hover {
    border-color: rgba(var(--color-foreground), 0.2);
    box-shadow: 0 10px 20px rgba(var(--color-foreground), 0.03);
  }
{%- endstyle -%}

<div class="custom-usp-grid color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding {% if section.settings.show_borders %}custom-usp-grid--borders{% endif %}">
  <div class="page-width">
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin text-center" style="margin-bottom: 3rem; display: flex; flex-direction: column; align-items: center;">
        {%- if section.settings.subtitle != blank -%}
          <p class="image-with-text__text image-with-text__text--caption" style="margin: 0 0 0.5rem 0; font-size: 1.3rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(var(--color-foreground), 0.7);">
            {{ section.settings.subtitle | escape }}
          </p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="title inline-richtext {{ section.settings.heading_size }}" style="margin: 0;">
            {{ section.settings.title | escape }}
          </h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="custom-usp-grid__wrapper">
      {%- for block in section.blocks -%}
        <div class="custom-usp-grid__item" {{ block.shopify_attributes }}>
          <div class="custom-usp-grid__icon-wrapper">
            {%- if block.settings.custom_image != blank -%}
              <img
                src="{{ block.settings.custom_image | image_url: width: 120 }}"
                alt="{{ block.settings.custom_image.alt | escape }}"
                loading="lazy"
                width="60"
                height="60"
                class="custom-usp-grid__icon-image"
              >
            {%- elsif block.settings.icon != 'none' -%}
              {%- assign file_name = block.settings.icon | replace: '_', '-' | prepend: 'icon-' | append: '.svg' -%}
              <span class="svg-wrapper" style="width: 48px; height: 48px; display: inline-block;">
                {{ file_name | inline_asset_content }}
              </span>
            {%- else -%}
              {% comment %} Fallback default SVG {% endcomment %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
              </svg>
            {%- endif -%}
          </div>

          {%- if block.settings.title != blank -%}
            <h3 class="custom-usp-grid__title h4">{{ block.settings.title | escape }}</h3>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <p class="custom-usp-grid__text body">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom USP Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Pure & Authentic Fragrances"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "The Mahekh Standard"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "checkbox",
      "id": "show_borders",
      "label": "Show border around cards",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36,
      "label": "Padding Bottom"
    }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "USP Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "perfume", "label": "Perfume Bottle" },
            { "value": "leaf", "label": "Leaf (Natural)" },
            { "value": "heart", "label": "Heart (Safe/Loving)" },
            { "value": "truck", "label": "Truck (Fast Delivery)" },
            { "value": "star", "label": "Star" },
            { "value": "stopwatch", "label": "Stopwatch (Long Lasting)" },
            { "value": "lightning_bolt", "label": "Lightning" }
          ],
          "default": "perfume"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Icon Image",
          "info": "Overrides the icon selection above if uploaded."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "USP Title"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Description",
          "default": "Describe your brand promise or product feature here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom USP Grid",
      "blocks": [
        {
          "type": "usp",
          "settings": {
            "icon": "perfume",
            "title": "100% Alcohol-Free",
            "text": "Pure concentrated perfume oil that is gentle on your skin."
          }
        },
        {
          "type": "usp",
          "settings": {
            "icon": "stopwatch",
            "title": "Long Lasting",
            "text": "Carefully selected ingredients that keep you fragrant all day long."
          }
        },
        {
          "type": "usp",
          "settings": {
            "icon": "leaf",
            "title": "Natural Craftsmanship",
            "text": "Traditional steam distillation process (Deg-Bhapka) from Kannauj."
          }
        },
        {
          "type": "usp",
          "settings": {
            "icon": "heart",
            "title": "Premium & Pure",
            "text": "No animal testing, crafted with clean and authentic ingredients."
          }
        }
      ]
    }
  ]
}
{% endschema %}
