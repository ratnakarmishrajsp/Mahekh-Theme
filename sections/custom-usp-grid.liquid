{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Premium Ivory-Cream and Gold USP Grid */
  .custom-usp-grid {
    text-align: center;
    background: #faf8f5 !important; /* Premium Ivory-Cream background matching rest of store */
    color: #121212 !important;
    position: relative;
    border-top: 1px solid rgba(204, 164, 59, 0.15);
    border-bottom: 1px solid rgba(204, 164, 59, 0.15);
  }

  .custom-usp-grid__wrapper {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: repeat(2, 1fr);
    position: relative;
    z-index: 2;
  }

  @media screen and (min-width: 750px) {
    .custom-usp-grid__wrapper {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: 3.5rem;
    }
  }

  .custom-usp-grid__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3.5rem 2rem;
    border-radius: 8px;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    background: #ffffff; /* White card layout */
    border: 1px solid rgba(204, 164, 59, 0.15); /* Gold outline borders */
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.02);
  }

  .custom-usp-grid__item:hover {
    transform: translateY(-8px);
    border-color: #cca43b; /* Pure metallic gold border */
    background: rgba(204, 164, 59, 0.02);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.05), 0 0 15px rgba(204, 164, 59, 0.1);
  }

  .custom-usp-grid__icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    width: 56px;
    height: 56px;
    color: #cca43b; /* Metallic gold color for icons */
    transition: transform 0.4s ease;
  }

  .custom-usp-grid__item:hover .custom-usp-grid__icon-wrapper {
    transform: scale(1.15) rotate(5deg);
  }

  .custom-usp-grid__icon-wrapper svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .custom-usp-grid__icon-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .custom-usp-grid__title {
    margin: 0 0 1.2rem 0;
    font-weight: 600;
    font-size: 1.5rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #121212 !important;
    font-family: 'Playfair Display', serif; /* Serif font for royal header */
  }

  .custom-usp-grid__text {
    margin: 0;
    line-height: 1.65;
    opacity: 0.8;
    font-size: 1.35rem;
    color: #4a453e !important;
  }

  .custom-usp-grid__subtitle-text {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    color: #cca43b !important;
  }
{%- endstyle -%}

<div class="custom-usp-grid section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin text-center" style="margin-bottom: 4.5rem; display: flex; flex-direction: column; align-items: center; position: relative; z-index: 2;">
        {%- if section.settings.subtitle != blank -%}
          <p class="image-with-text__text image-with-text__text--caption custom-usp-grid__subtitle-text" style="margin: 0 0 0.8rem 0; font-size: 1.5rem; letter-spacing: 0.15em; text-transform: uppercase;">
            {{ section.settings.subtitle | escape }}
          </p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="title inline-richtext {{ section.settings.heading_size }}" style="margin: 0; font-family: 'Playfair Display', serif; font-weight: 600; color: #121212; letter-spacing: 0.03em;">
            {{ section.settings.title | escape }}
          </h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="custom-usp-grid__wrapper">
      {%- for block in section.blocks -%}
        <div class="custom-usp-grid__item" {{ block.shopify_attributes }}>
          <div class="custom-usp-grid__icon-wrapper">
            {%- if block.settings.custom_image != blank -%}
              <img
                src="{{ block.settings.custom_image | image_url: width: 120 }}"
                alt="{{ block.settings.custom_image.alt | escape }}"
                loading="lazy"
                width="56"
                height="56"
                class="custom-usp-grid__icon-image"
              >
            {%- elsif block.settings.icon != 'none' -%}
              {%- assign file_name = block.settings.icon | replace: '_', '-' | prepend: 'icon-' | append: '.svg' -%}
              <span class="svg-wrapper" style="width: 44px; height: 44px; display: inline-block;">
                {{ file_name | inline_asset_content }}
              </span>
            {%- else -%}
              {% comment %} Fallback default SVG {% endcomment %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
              </svg>
            {%- endif -%}
          </div>

          {%- if block.settings.title != blank -%}
            <h3 class="custom-usp-grid__title h4">{{ block.settings.title | escape }}</h3>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <p class="custom-usp-grid__text body">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom USP Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Pure & Authentic Fragrances"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "The Mahekh Standard"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Padding Bottom"
    }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "USP Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "perfume", "label": "Perfume Bottle" },
            { "value": "leaf", "label": "Leaf (Natural)" },
            { "value": "heart", "label": "Heart (Safe/Loving)" },
            { "value": "truck", "label": "Truck (Fast Delivery)" },
            { "value": "star", "label": "Star" },
            { "value": "stopwatch", "label": "Stopwatch (Long Lasting)" },
            { "value": "lightning_bolt", "label": "Lightning" }
          ],
          "default": "perfume"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Icon Image",
          "info": "Overrides the icon selection above if uploaded."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "USP Title"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Description",
          "default": "Describe your brand promise or product feature here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom USP Grid",
      "blocks": [
        {
          "type": "usp",
          "settings": {
            "icon": "perfume",
            "title": "100% Alcohol-Free",
            "text": "Pure concentrated perfume oil that is gentle on your skin."
          }
        },
        {
          "type": "usp",
          "settings": {
            "icon": "stopwatch",
            "title": "Long Lasting",
            "text": "Carefully selected ingredients that keep you fragrant all day long."
          }
        },
        {
          "type": "usp",
          "settings": {
            "icon": "leaf",
            "title": "Natural Craftsmanship",
            "text": "Traditional steam distillation process (Deg-Bhapka) from Kannauj."
          }
        },
        {
          "type": "usp",
          "settings": {
            "icon": "heart",
            "title": "Premium & Pure",
            "text": "No animal testing, crafted with clean and authentic ingredients."
          }
        }
      ]
    }
  ]
}
{% endschema %}
