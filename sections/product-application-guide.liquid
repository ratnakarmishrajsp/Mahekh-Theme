{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .app-guide {
    text-align: center;
  }

  .app-guide__title-wrapper {
    margin-bottom: 4rem;
  }

  .app-guide__subtitle {
    margin: 0 0 0.5rem 0;
    font-size: 1.3rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(var(--color-foreground), 0.7);
  }

  .app-guide__title {
    margin: 0;
  }

  .app-guide__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media screen and (min-width: 750px) {
    .app-guide__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 4rem;
    }
  }

  .app-guide__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 3rem 2rem;
    border-radius: 8px;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    position: relative;
    transition: transform 0.3s, border-color 0.3s;
    background: transparent;
  }

  .app-guide__card:hover {
    transform: translateY(-4px);
    border-color: rgba(var(--color-foreground), 0.2);
  }

  .app-guide__step-number {
    position: absolute;
    top: 1.5rem;
    right: 2rem;
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
    color: rgba(var(--color-foreground), 0.04);
    font-family: serif;
  }

  .app-guide__icon-wrapper {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(var(--color-foreground), 0.04);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
    color: rgb(var(--color-foreground));
    border: 1px solid rgba(var(--color-foreground), 0.08);
  }

  .app-guide__icon-wrapper svg {
    width: 32px;
    height: 32px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  .app-guide__card-title {
    margin: 0 0 1rem 0;
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .app-guide__card-desc {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.6;
    opacity: 0.85;
  }
{%- endstyle -%}

<div class="app-guide color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="app-guide__title-wrapper">
        {%- if section.settings.subtitle != blank -%}
          <p class="app-guide__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="app-guide__title inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.title | escape }}
          </h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="app-guide__grid">
      
      {% comment %} Step 1 {% endcomment %}
      <div class="app-guide__card">
        <span class="app-guide__step-number">01</span>
        <div class="app-guide__icon-wrapper">
          {% comment %} Pulse Points SVG (heart / dot) {% endcomment %}
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
        </div>
        <h3 class="app-guide__card-title">{{ section.settings.step_1_title }}</h3>
        <p class="app-guide__card-desc body">{{ section.settings.step_1_desc }}</p>
      </div>

      {% comment %} Step 2 {% endcomment %}
      <div class="app-guide__card">
        <span class="app-guide__step-number">02</span>
        <div class="app-guide__icon-wrapper">
          {% comment %} Dab don't rub SVG (hands crossing / circle) {% endcomment %}
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.05 4.575a1.5 1.5 0 10-2.23-2.014L3.82 8.061a4.99 4.99 0 001.41 7.795L10.5 18.75m3.75-2.25l3.54-3.54a5.002 5.002 0 00-7.07-7.07l-1.41 1.41m2.82 2.83l-1.41 1.41" />
          </svg>
        </div>
        <h3 class="app-guide__card-title">{{ section.settings.step_2_title }}</h3>
        <p class="app-guide__card-desc body">{{ section.settings.step_2_desc }}</p>
      </div>

      {% comment %} Step 3 {% endcomment %}
      <div class="app-guide__card">
        <span class="app-guide__step-number">03</span>
        <div class="app-guide__icon-wrapper">
          {% comment %} Moisturization/Drop SVG {% endcomment %}
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
        </div>
        <h3 class="app-guide__card-title">{{ section.settings.step_3_title }}</h3>
        <p class="app-guide__card-desc body">{{ section.settings.step_3_desc }}</p>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Attar Application Guide",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "How To Apply Concentrated Attar"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "LONGEVITY GUIDE"
    },
    {
      "type": "header",
      "content": "Step 1 Settings"
    },
    {
      "type": "text",
      "id": "step_1_title",
      "label": "Step 1 Title",
      "default": "Apply on Pulse Points"
    },
    {
      "type": "textarea",
      "id": "step_1_desc",
      "label": "Step 1 Description",
      "default": "Apply the perfume oil directly to pulse points (wrists, inner elbows, neck, and behind ears). Body heat in these spots diffuses the scent naturally."
    },
    {
      "type": "header",
      "content": "Step 2 Settings"
    },
    {
      "type": "text",
      "id": "step_2_title",
      "label": "Step 2 Title",
      "default": "Dab, Don't Rub"
    },
    {
      "type": "textarea",
      "id": "step_2_desc",
      "label": "Step 2 Description",
      "default": "Gently dab the oil on your skin. Never rub wrists together, as rubbing friction breaks down the delicate top note molecules and reduces scent longevity."
    },
    {
      "type": "header",
      "content": "Step 3 Settings"
    },
    {
      "type": "text",
      "id": "step_3_title",
      "label": "Step 3 Title",
      "default": "Moisturize First"
    },
    {
      "type": "textarea",
      "id": "step_3_desc",
      "label": "Step 3 Description",
      "default": "Fragrance lasts significantly longer on moisturized skin. Apply an unscented moisturizer or lotion to pulse points before dabbing your attar."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36,
      "label": "Padding Bottom"
    }
  ],
  "presets": [
    {
      "name": "Attar Application Guide"
    }
  ]
}
{% endschema %}
