{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .fragrance-profile {
    position: relative;
  }

  .fragrance-profile__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem;
  }

  @media screen and (min-width: 990px) {
    .fragrance-profile__grid {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 6rem;
    }
  }

  .fragrance-profile__title-wrapper {
    margin-bottom: 3.5rem;
    text-align: center;
  }

  .fragrance-profile__subtitle {
    margin: 0 0 0.5rem 0;
    font-size: 1.3rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(var(--color-foreground), 0.7);
  }

  .fragrance-profile__title {
    margin: 0;
  }

  /* Pyramid / Scent Notes Styling */
  .fragrance-profile__notes {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .fragrance-profile__note-card {
    display: flex;
    gap: 2rem;
    padding: 2.2rem;
    border-radius: 8px;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    background: transparent;
    transition: border-color 0.3s, transform 0.3s;
  }

  .fragrance-profile__note-card:hover {
    border-color: rgba(var(--color-foreground), 0.2);
    transform: translateX(4px);
  }

  .fragrance-profile__note-badge {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(var(--color-foreground), 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: rgb(var(--color-foreground));
    font-size: 1.2rem;
    font-weight: bold;
    letter-spacing: 0.05em;
    border: 1px solid rgba(var(--color-foreground), 0.1);
  }

  .fragrance-profile__note-content {
    flex-grow: 1;
  }

  .fragrance-profile__note-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.8rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .fragrance-profile__note-type {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .fragrance-profile__note-ingredients {
    margin: 0;
    font-size: 1.6rem;
    font-weight: 700;
    color: rgb(var(--color-foreground));
  }

  .fragrance-profile__note-desc {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.5;
    opacity: 0.8;
  }

  /* Performance Gauges Styling */
  .fragrance-profile__performance {
    padding: 3rem 2.5rem;
    border-radius: 8px;
    background: rgba(var(--color-foreground), 0.02);
    border: 1px solid rgba(var(--color-foreground), 0.05);
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    justify-content: center;
  }

  .fragrance-profile__gauge {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .fragrance-profile__gauge-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .fragrance-profile__gauge-label {
    opacity: 0.8;
  }

  .fragrance-profile__gauge-value {
    color: rgb(var(--color-foreground));
  }

  .fragrance-profile__bar-wrapper {
    position: relative;
    width: 100%;
    height: 8px;
    background: rgba(var(--color-foreground), 0.1);
    border-radius: 4px;
    overflow: hidden;
  }

  .fragrance-profile__bar-fill {
    height: 100%;
    border-radius: 4px;
    background: rgb(var(--color-foreground)); /* Fallback standard color */
    background: linear-gradient(90deg, rgba(var(--color-foreground), 0.6), rgb(var(--color-foreground)));
    transition: width 1s ease-out;
  }

  .fragrance-profile__gauge-markers {
    display: flex;
    justify-content: space-between;
    font-size: 1.1rem;
    opacity: 0.5;
    padding-top: 0.2rem;
  }

  .fragrance-profile__best-suited {
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
    padding-top: 2rem;
    margin-top: 1rem;
  }

  .fragrance-profile__best-suited-title {
    margin: 0 0 0.6rem 0;
    font-size: 1.3rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.7;
  }

  .fragrance-profile__best-suited-text {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
  }
{%- endstyle -%}

<div class="fragrance-profile color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="fragrance-profile__title-wrapper">
        {%- if section.settings.subtitle != blank -%}
          <p class="fragrance-profile__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="fragrance-profile__title inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.title | escape }}
          </h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="fragrance-profile__grid">
      
      {% comment %} Olfactory Notes Pyramid {% endcomment %}
      <div class="fragrance-profile__notes">
        
        {%- if section.settings.top_note_ingredients != blank -%}
          <div class="fragrance-profile__note-card">
            <div class="fragrance-profile__note-badge" aria-hidden="true">TOP</div>
            <div class="fragrance-profile__note-content">
              <div class="fragrance-profile__note-header">
                <span class="fragrance-profile__note-type">{{ section.settings.top_note_label }}</span>
                <span class="fragrance-profile__note-ingredients">{{ section.settings.top_note_ingredients }}</span>
              </div>
              {%- if section.settings.top_note_desc != blank -%}
                <p class="fragrance-profile__note-desc">{{ section.settings.top_note_desc }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.heart_note_ingredients != blank -%}
          <div class="fragrance-profile__note-card">
            <div class="fragrance-profile__note-badge" aria-hidden="true">MID</div>
            <div class="fragrance-profile__note-content">
              <div class="fragrance-profile__note-header">
                <span class="fragrance-profile__note-type">{{ section.settings.heart_note_label }}</span>
                <span class="fragrance-profile__note-ingredients">{{ section.settings.heart_note_ingredients }}</span>
              </div>
              {%- if section.settings.heart_note_desc != blank -%}
                <p class="fragrance-profile__note-desc">{{ section.settings.heart_note_desc }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.base_note_ingredients != blank -%}
          <div class="fragrance-profile__note-card">
            <div class="fragrance-profile__note-badge" aria-hidden="true">BASE</div>
            <div class="fragrance-profile__note-content">
              <div class="fragrance-profile__note-header">
                <span class="fragrance-profile__note-type">{{ section.settings.base_note_label }}</span>
                <span class="fragrance-profile__note-ingredients">{{ section.settings.base_note_ingredients }}</span>
              </div>
              {%- if section.settings.base_note_desc != blank -%}
                <p class="fragrance-profile__note-desc">{{ section.settings.base_note_desc }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

      </div>

      {% comment %} Performance Scent Gauges {% endcomment %}
      <div class="fragrance-profile__performance">
        
        {% comment %} Longevity Gauge {% endcomment %}
        <div class="fragrance-profile__gauge">
          <div class="fragrance-profile__gauge-header">
            <span class="fragrance-profile__gauge-label">Longevity</span>
            <span class="fragrance-profile__gauge-value">{{ section.settings.longevity_hours }} Hours</span>
          </div>
          <div class="fragrance-profile__bar-wrapper">
            {%- assign longevity_percentage = section.settings.longevity_hours | times: 8.33 -%}
            {%- if longevity_percentage > 100 -%}{%- assign longevity_percentage = 100 -%}{%- endif -%}
            <div class="fragrance-profile__bar-fill" style="width: {{ longevity_percentage }}%;"></div>
          </div>
          <div class="fragrance-profile__gauge-markers">
            <span>2 hrs</span>
            <span>6 hrs</span>
            <span>12+ hrs</span>
          </div>
        </div>

        {% comment %} Sillage Gauge {% endcomment %}
        <div class="fragrance-profile__gauge">
          <div class="fragrance-profile__gauge-header">
            <span class="fragrance-profile__gauge-label">Sillage (Projection)</span>
            <span class="fragrance-profile__gauge-value">{{ section.settings.sillage_text }}</span>
          </div>
          <div class="fragrance-profile__bar-wrapper">
            {%- assign sillage_percentage = section.settings.sillage_rating | times: 20 -%}
            <div class="fragrance-profile__bar-fill" style="width: {{ sillage_percentage }}%;"></div>
          </div>
          <div class="fragrance-profile__gauge-markers">
            <span>Intimate</span>
            <span>Moderate</span>
            <span>Strong</span>
          </div>
        </div>

        {% comment %} Intensity Gauge {% endcomment %}
        <div class="fragrance-profile__gauge">
          <div class="fragrance-profile__gauge-header">
            <span class="fragrance-profile__gauge-label">Intensity</span>
            <span class="fragrance-profile__gauge-value">{{ section.settings.intensity_text }}</span>
          </div>
          <div class="fragrance-profile__bar-wrapper">
            {%- assign intensity_percentage = section.settings.intensity_rating | times: 20 -%}
            <div class="fragrance-profile__bar-fill" style="width: {{ intensity_percentage }}%;"></div>
          </div>
          <div class="fragrance-profile__gauge-markers">
            <span>Mild</span>
            <span>Balanced</span>
            <span>Rich & Deep</span>
          </div>
        </div>

        {% comment %} Best Suited For {% endcomment %}
        {%- if section.settings.best_suited != blank -%}
          <div class="fragrance-profile__best-suited">
            <h3 class="fragrance-profile__best-suited-title">{{ section.settings.best_suited_label }}</h3>
            <p class="fragrance-profile__best-suited-text">{{ section.settings.best_suited }}</p>
          </div>
        {%- endif -%}

      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Fragrance Profile & Notes",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Fragrance Profile"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Scent Anatomy"
    },
    {
      "type": "header",
      "content": "Scent Notes (Top, Heart, Base)"
    },
    {
      "type": "text",
      "id": "top_note_label",
      "label": "Top Note Label",
      "default": "Top Note"
    },
    {
      "type": "text",
      "id": "top_note_ingredients",
      "label": "Top Note Ingredients",
      "default": "Saffron, Cardamom"
    },
    {
      "type": "text",
      "id": "top_note_desc",
      "label": "Top Note Description",
      "default": "The opening notes provide a luxurious spicy warmth upon application."
    },
    {
      "type": "text",
      "id": "heart_note_label",
      "label": "Heart Note Label",
      "default": "Heart Note"
    },
    {
      "type": "text",
      "id": "heart_note_ingredients",
      "label": "Heart Note Ingredients",
      "default": "Kannauj Rose, Jasmine"
    },
    {
      "type": "text",
      "id": "heart_note_desc",
      "label": "Heart Note Description",
      "default": "The core of the fragrance reveals elegant floral layers that smooth the spices."
    },
    {
      "type": "text",
      "id": "base_note_label",
      "label": "Base Note Label",
      "default": "Base Note"
    },
    {
      "type": "text",
      "id": "base_note_ingredients",
      "label": "Base Note Ingredients",
      "default": "Royal Oudh, Sandalwood, Musk"
    },
    {
      "type": "text",
      "id": "base_note_desc",
      "label": "Base Note Description",
      "default": "The deep, rich foundation remains on your skin for hours with a warm, woody trails."
    },
    {
      "type": "header",
      "content": "Scent Performance (Gauges)"
    },
    {
      "type": "range",
      "id": "longevity_hours",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 10,
      "label": "Longevity (Hours)"
    },
    {
      "type": "range",
      "id": "sillage_rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Sillage / Projection Rating"
    },
    {
      "type": "text",
      "id": "sillage_text",
      "label": "Sillage Label Text",
      "default": "Strong / Radiating"
    },
    {
      "type": "range",
      "id": "intensity_rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Intensity Rating"
    },
    {
      "type": "text",
      "id": "intensity_text",
      "label": "Intensity Label Text",
      "default": "Warm & Rich"
    },
    {
      "type": "text",
      "id": "best_suited_label",
      "label": "Best Suited For Label",
      "default": "Best Suited For"
    },
    {
      "type": "text",
      "id": "best_suited",
      "label": "Best Suited For Text",
      "default": "Special occasions, cool evenings, and ceremonial wear."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36,
      "label": "Padding Bottom"
    }
  ],
  "presets": [
    {
      "name": "Fragrance Profile & Notes"
    }
  ]
}
{% endschema %}
