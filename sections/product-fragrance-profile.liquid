{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Royal Fragrance Profile Theme */
  .fragrance-profile {
    position: relative;
    background: radial-gradient(circle at center, #18120f 0%, #0d0908 100%) !important;
    color: #f5f0e6 !important;
    border-top: 1px solid rgba(204, 164, 59, 0.1);
    border-bottom: 1px solid rgba(204, 164, 59, 0.1);
  }

  .fragrance-profile__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media screen and (min-width: 990px) {
    .fragrance-profile__grid {
      grid-template-columns: 1.1fr 0.8fr 1.1fr;
      gap: 5rem;
    }
  }

  .fragrance-profile__title-wrapper {
    margin-bottom: 4rem;
    text-align: center;
  }

  .fragrance-profile__subtitle {
    margin: 0 0 0.5rem 0;
    font-size: 1.4rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #cca43b !important;
    font-family: 'Playfair Display', serif;
    font-style: italic;
  }

  .fragrance-profile__title {
    margin: 0;
    font-family: 'Playfair Display', serif;
    font-weight: 600;
    color: #ffffff;
  }

  /* Scent Notes Pyramid styling */
  .fragrance-profile__notes {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .fragrance-profile__note-card {
    display: flex;
    gap: 2rem;
    padding: 2.2rem;
    border-radius: 8px;
    border: 1px solid rgba(204, 164, 59, 0.1);
    background: rgba(255, 255, 255, 0.01);
    transition: all 0.3s ease;
  }

  .fragrance-profile__note-card:hover {
    border-color: #cca43b;
    transform: translateX(6px);
    background: rgba(204, 164, 59, 0.02);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
  }

  .fragrance-profile__note-badge {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(204, 164, 59, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #cca43b;
    font-size: 1.1rem;
    font-weight: bold;
    letter-spacing: 0.05em;
    border: 1px solid rgba(204, 164, 59, 0.2);
  }

  .fragrance-profile__note-content {
    flex-grow: 1;
  }

  .fragrance-profile__note-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.8rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .fragrance-profile__note-type {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.6);
  }

  .fragrance-profile__note-ingredients {
    margin: 0;
    font-size: 1.6rem;
    font-weight: 700;
    color: #ffffff;
    font-family: 'Playfair Display', serif;
  }

  .fragrance-profile__note-desc {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.5;
    color: #d1cbbd;
  }

  /* Center Illustration: Pure Gold Drop */
  .fragrance-profile__center-illustration {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    padding: 2rem 0;
  }

  .fragrance-profile__drop-container {
    position: relative;
    width: 100%;
    max-width: 260px;
    border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%; /* Organic drops shape border */
    overflow: hidden;
    border: 1px solid rgba(204, 164, 59, 0.15);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.4);
    animation: floatDrop 5s ease-in-out infinite;
    background: rgba(204, 164, 59, 0.02);
  }

  /* Gold frame inside the drop card */
  .fragrance-profile__drop-container::before {
    content: '';
    position: absolute;
    top: 8px;
    left: 8px;
    right: 8px;
    bottom: 8px;
    border: 1px solid rgba(204, 164, 59, 0.15);
    border-radius: 50% 50% 50% 50% / 40% 40% 60% 60%;
    pointer-events: none;
    z-index: 1;
  }

  .fragrance-profile__drop-img {
    width: 100%;
    height: auto;
    display: block;
    mix-blend-mode: screen; /* Blends pure drop light into dark bg */
    transition: transform 0.6s ease;
  }

  .fragrance-profile__drop-container:hover .fragrance-profile__drop-img {
    transform: scale(1.08);
  }

  @keyframes floatDrop {
    0% { transform: translateY(0px) scale(1); }
    50% { transform: translateY(-12px) scale(1.02); }
    100% { transform: translateY(0px) scale(1); }
  }

  /* Performance Gauges styling */
  .fragrance-profile__performance {
    padding: 3.5rem 3rem;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid rgba(204, 164, 59, 0.1);
    display: flex;
    flex-direction: column;
    gap: 2.8rem;
    justify-content: center;
  }

  .fragrance-profile__gauge {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .fragrance-profile__gauge-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .fragrance-profile__gauge-label {
    color: rgba(255,255,255,0.7);
  }

  .fragrance-profile__gauge-value {
    color: #cca43b; /* Gold highlights */
    font-weight: bold;
  }

  .fragrance-profile__bar-wrapper {
    position: relative;
    width: 100%;
    height: 6px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 3px;
    overflow: hidden;
  }

  .fragrance-profile__bar-fill {
    height: 100%;
    border-radius: 3px;
    background: linear-gradient(90deg, #cca43b, #f1cb64); /* Pure gold gradients */
    box-shadow: 0 0 8px rgba(204, 164, 59, 0.4);
    transition: width 1s ease-out;
  }

  .fragrance-profile__gauge-markers {
    display: flex;
    justify-content: space-between;
    font-size: 1.1rem;
    opacity: 0.4;
    padding-top: 0.2rem;
  }

  .fragrance-profile__best-suited {
    border-top: 1px solid rgba(204, 164, 59, 0.15);
    padding-top: 2rem;
    margin-top: 1rem;
  }

  .fragrance-profile__best-suited-title {
    margin: 0 0 0.6rem 0;
    font-size: 1.3rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.6);
  }

  .fragrance-profile__best-suited-text {
    margin: 0;
    font-size: 1.45rem;
    color: #ffffff;
    font-family: 'Playfair Display', serif;
    font-style: italic;
  }
{%- endstyle -%}

<div class="fragrance-profile section-{{ section.id }}-padding">
  <div class="page-width">
    
    {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="fragrance-profile__title-wrapper">
        {%- if section.settings.subtitle != blank -%}
          <p class="fragrance-profile__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="fragrance-profile__title inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.title | escape }}
          </h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="fragrance-profile__grid">
      
      {% comment %} Column 1: Olfactory Notes Pyramid {% endcomment %}
      <div class="fragrance-profile__notes">
        
        {%- if section.settings.top_note_ingredients != blank -%}
          <div class="fragrance-profile__note-card">
            <div class="fragrance-profile__note-badge" aria-hidden="true">TOP</div>
            <div class="fragrance-profile__note-content">
              <div class="fragrance-profile__note-header">
                <span class="fragrance-profile__note-type">{{ section.settings.top_note_label }}</span>
                <span class="fragrance-profile__note-ingredients">{{ section.settings.top_note_ingredients }}</span>
              </div>
              {%- if section.settings.top_note_desc != blank -%}
                <p class="fragrance-profile__note-desc">{{ section.settings.top_note_desc }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.heart_note_ingredients != blank -%}
          <div class="fragrance-profile__note-card">
            <div class="fragrance-profile__note-badge" aria-hidden="true">MID</div>
            <div class="fragrance-profile__note-content">
              <div class="fragrance-profile__note-header">
                <span class="fragrance-profile__note-type">{{ section.settings.heart_note_label }}</span>
                <span class="fragrance-profile__note-ingredients">{{ section.settings.heart_note_ingredients }}</span>
              </div>
              {%- if section.settings.heart_note_desc != blank -%}
                <p class="fragrance-profile__note-desc">{{ section.settings.heart_note_desc }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

        {%- if section.settings.base_note_ingredients != blank -%}
          <div class="fragrance-profile__note-card">
            <div class="fragrance-profile__note-badge" aria-hidden="true">BASE</div>
            <div class="fragrance-profile__note-content">
              <div class="fragrance-profile__note-header">
                <span class="fragrance-profile__note-type">{{ section.settings.base_note_label }}</span>
                <span class="fragrance-profile__note-ingredients">{{ section.settings.base_note_ingredients }}</span>
              </div>
              {%- if section.settings.base_note_desc != blank -%}
                <p class="fragrance-profile__note-desc">{{ section.settings.base_note_desc }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}

      </div>

      {% comment %} Column 2: Pure Gold Drop Illustration (Floating Card) {% endcomment %}
      <div class="fragrance-profile__center-illustration">
        <div class="fragrance-profile__drop-container">
          <img
            src="{{ 'pure-drop.png' | asset_url }}"
            alt="Pure concentrated attar essential oil gold drop illustration"
            loading="lazy"
            width="260"
            height="360"
            class="fragrance-profile__drop-img"
          >
        </div>
      </div>

      {% comment %} Column 3: Performance Scent Gauges {% endcomment %}
      <div class="fragrance-profile__performance">
        
        {% comment %} Longevity Gauge {% endcomment %}
        <div class="fragrance-profile__gauge">
          <div class="fragrance-profile__gauge-header">
            <span class="fragrance-profile__gauge-label">Longevity</span>
            <span class="fragrance-profile__gauge-value">{{ section.settings.longevity_hours }} Hours</span>
          </div>
          <div class="fragrance-profile__bar-wrapper">
            {%- assign longevity_percentage = section.settings.longevity_hours | times: 8.33 -%}
            {%- if longevity_percentage > 100 -%}{%- assign longevity_percentage = 100 -%}{%- endif -%}
            <div class="fragrance-profile__bar-fill" style="width: {{ longevity_percentage }}%;"></div>
          </div>
          <div class="fragrance-profile__gauge-markers">
            <span>2 hrs</span>
            <span>6 hrs</span>
            <span>12+ hrs</span>
          </div>
        </div>

        {% comment %} Sillage Gauge {% endcomment %}
        <div class="fragrance-profile__gauge">
          <div class="fragrance-profile__gauge-header">
            <span class="fragrance-profile__gauge-label">Sillage (Projection)</span>
            <span class="fragrance-profile__gauge-value">{{ section.settings.sillage_text }}</span>
          </div>
          <div class="fragrance-profile__bar-wrapper">
            {%- assign sillage_percentage = section.settings.sillage_rating | times: 20 -%}
            <div class="fragrance-profile__bar-fill" style="width: {{ sillage_percentage }}%;"></div>
          </div>
          <div class="fragrance-profile__gauge-markers">
            <span>Intimate</span>
            <span>Moderate</span>
            <span>Strong</span>
          </div>
        </div>

        {% comment %} Intensity Gauge {% endcomment %}
        <div class="fragrance-profile__gauge">
          <div class="fragrance-profile__gauge-header">
            <span class="fragrance-profile__gauge-label">Intensity</span>
            <span class="fragrance-profile__gauge-value">{{ section.settings.intensity_text }}</span>
          </div>
          <div class="fragrance-profile__bar-wrapper">
            {%- assign intensity_percentage = section.settings.intensity_rating | times: 20 -%}
            <div class="fragrance-profile__bar-fill" style="width: {{ intensity_percentage }}%;"></div>
          </div>
          <div class="fragrance-profile__gauge-markers">
            <span>Mild</span>
            <span>Balanced</span>
            <span>Rich & Deep</span>
          </div>
        </div>

        {% comment %} Best Suited For {% endcomment %}
        {%- if section.settings.best_suited != blank -%}
          <div class="fragrance-profile__best-suited">
            <h3 class="fragrance-profile__best-suited-title">{{ section.settings.best_suited_label }}</h3>
            <p class="fragrance-profile__best-suited-text">{{ section.settings.best_suited }}</p>
          </div>
        {%- endif -%}

      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Fragrance Profile & Notes",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Fragrance Profile"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Scent Anatomy"
    },
    {
      "type": "header",
      "content": "Scent Notes (Top, Heart, Base)"
    },
    {
      "type": "text",
      "id": "top_note_label",
      "label": "Top Note Label",
      "default": "Top Note"
    },
    {
      "type": "text",
      "id": "top_note_ingredients",
      "label": "Top Note Ingredients",
      "default": "Saffron, Cardamom"
    },
    {
      "type": "text",
      "id": "top_note_desc",
      "label": "Top Note Description",
      "default": "The opening notes provide a luxurious spicy warmth upon application."
    },
    {
      "type": "text",
      "id": "heart_note_label",
      "label": "Heart Note Label",
      "default": "Heart Note"
    },
    {
      "type": "text",
      "id": "heart_note_ingredients",
      "label": "Heart Note Ingredients",
      "default": "Kannauj Rose, Jasmine"
    },
    {
      "type": "text",
      "id": "heart_note_desc",
      "label": "Heart Note Description",
      "default": "The core of the fragrance reveals elegant floral layers that smooth the spices."
    },
    {
      "type": "text",
      "id": "base_note_label",
      "label": "Base Note Label",
      "default": "Base Note"
    },
    {
      "type": "text",
      "id": "base_note_ingredients",
      "label": "Base Note Ingredients",
      "default": "Royal Oudh, Sandalwood, Musk"
    },
    {
      "type": "text",
      "id": "base_note_desc",
      "label": "Base Note Description",
      "default": "The deep, rich foundation remains on your skin for hours with a warm, woody trail."
    },
    {
      "type": "header",
      "content": "Scent Performance (Gauges)"
    },
    {
      "type": "range",
      "id": "longevity_hours",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 10,
      "label": "Longevity (Hours)"
    },
    {
      "type": "range",
      "id": "sillage_rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Sillage / Projection Rating"
    },
    {
      "type": "text",
      "id": "sillage_text",
      "label": "Sillage Label Text",
      "default": "Strong / Radiating"
    },
    {
      "type": "range",
      "id": "intensity_rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Intensity Rating"
    },
    {
      "type": "text",
      "id": "intensity_text",
      "label": "Intensity Label Text",
      "default": "Warm & Rich"
    },
    {
      "type": "text",
      "id": "best_suited_label",
      "label": "Best Suited For Label",
      "default": "Best Suited For"
    },
    {
      "type": "text",
      "id": "best_suited",
      "label": "Best Suited For Text",
      "default": "Special occasions, cool evenings, and ceremonial wear."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48,
      "label": "Padding Bottom"
    }
  ],
  "presets": [
    {
      "name": "Fragrance Profile & Notes"
    }
  ]
}
{% endschema %}
