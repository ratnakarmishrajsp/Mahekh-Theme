{%- liquid
  assign featured_product = section.settings.product
  if featured_product != blank
    assign product_image = featured_product.featured_media | image_url: width: 600
    assign product_title = featured_product.title
    assign product_price = featured_product.price | money
    assign product_url = featured_product.url
    assign product_available = featured_product.available
  else
    assign product_title = "Kasturi Musk Premium Attar"
    assign product_price = "Rs. 1,499"
    assign product_url = "#"
    assign product_available = true
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-hero {
    position: relative;
    overflow: hidden;
  }

  .custom-hero__bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    opacity: {{ section.settings.bg_image_opacity | divided_by: 100.0 }};
  }

  .custom-hero__container {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media screen and (min-width: 990px) {
    .custom-hero__container {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 8rem;
    }
  }

  .custom-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .custom-hero__subheading {
    font-size: 1.3rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    margin: 0 0 1.5rem 0;
    color: rgba(var(--color-foreground), 0.85);
  }

  .custom-hero__heading {
    margin: 0 0 2rem 0;
    line-height: 1.15;
    font-weight: 700;
  }

  .custom-hero__desc {
    font-size: 1.6rem;
    line-height: 1.7;
    margin: 0 0 3.5rem 0;
    opacity: 0.85;
  }

  .custom-hero__cta {
    z-index: 2;
  }

  /* Product Card Showcase Styling */
  .custom-hero__showcase {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .custom-hero__product-card {
    background: rgba(var(--color-background), 0.8);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(var(--color-foreground), 0.08);
    border-radius: 12px;
    padding: 2.5rem;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), border-color 0.4s ease;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
  }

  .custom-hero__product-card:hover {
    transform: translateY(-8px);
    border-color: rgba(var(--color-foreground), 0.2);
  }

  /* Thin gold border inner frame for premium luxury feel */
  .custom-hero__product-card::before {
    content: '';
    position: absolute;
    top: 8px;
    left: 8px;
    right: 8px;
    bottom: 8px;
    border: 1px solid rgba(var(--color-foreground), 0.03);
    pointer-events: none;
    border-radius: 8px;
  }

  .custom-hero__image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 6px;
    background: rgba(var(--color-foreground), 0.02);
    margin-bottom: 2rem;
  }

  .custom-hero__product-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.5s ease;
  }

  .custom-hero__product-card:hover .custom-hero__product-image {
    transform: scale(1.04);
  }

  .custom-hero__product-info {
    text-align: center;
  }

  .custom-hero__product-badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: rgba(var(--color-foreground), 0.05);
    border-radius: 30px;
    margin-bottom: 1.2rem;
  }

  .custom-hero__product-title {
    margin: 0 0 0.8rem 0;
    font-weight: 600;
    font-size: 1.8rem;
    line-height: 1.3;
  }

  .custom-hero__product-price {
    font-size: 1.6rem;
    font-weight: 700;
    color: rgb(var(--color-foreground));
    margin-bottom: 2rem;
    display: block;
  }

  .custom-hero__product-button {
    width: 100%;
    padding: 1.2rem;
    font-size: 1.3rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 4px;
    border: 1px solid rgb(var(--color-foreground));
    background: transparent;
    color: rgb(var(--color-foreground));
    transition: background 0.3s, color 0.3s;
    display: block;
    text-align: center;
    box-sizing: border-box;
  }

  .custom-hero__product-card:hover .custom-hero__product-button {
    background: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
  }
{%- endstyle -%}

<div class="custom-hero color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  
  {%- if section.settings.bg_image != blank -%}
    <img
      src="{{ section.settings.bg_image | image_url: width: 1800 }}"
      alt="{{ section.settings.bg_image.alt | escape }}"
      loading="eager"
      class="custom-hero__bg-image"
      width="1000"
      height="500"
    >
  {%- endif -%}

  <div class="page-width">
    <div class="custom-hero__container">
      
      {% comment %} Left Branding Content {% endcomment %}
      <div class="custom-hero__content">
        {%- if section.settings.subheading != blank -%}
          <span class="custom-hero__subheading">{{ section.settings.subheading | escape }}</span>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="custom-hero__heading inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.heading | escape }}
          </h1>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <p class="custom-hero__desc body">
            {{ section.settings.description | escape }}
          </p>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a
            {% if section.settings.button_link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.settings.button_link }}"
            {% endif %}
            class="button button--primary custom-hero__cta"
          >
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>

      {% comment %} Right Dynamic Product Card Showcase {% endcomment %}
      <div class="custom-hero__showcase">
        <a href="{{ product_url }}" class="custom-hero__product-card">
          <div class="custom-hero__image-wrapper">
            {%- if featured_product != blank and featured_product.featured_media != blank -%}
              <img
                src="{{ product_image }}"
                alt="{{ featured_product.featured_media.alt | escape }}"
                loading="eager"
                width="350"
                height="350"
                class="custom-hero__product-image"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg custom-hero__product-image' }}
            {%- endif -%}
          </div>
          <div class="custom-hero__product-info">
            <span class="custom-hero__product-badge">Flagship Fragrance</span>
            <h2 class="custom-hero__product-title h4">{{ product_title | escape }}</h2>
            <span class="custom-hero__product-price">{{ product_price }}</span>
            <span class="custom-hero__product-button">
              {%- if product_available -%}
                Explore Scent
              {%- else -%}
                Sold Out
              {%- endif -%}
            </span>
          </div>
        </a>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Product Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "100% Pure Concentrated Attars"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Kannauj's Finest Liquid Gold"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h0",
      "label": "Heading size"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "Experience the rich heritage of traditional Indian perfumery. Handcrafted in copper stills, our attars are completely alcohol-free, long-lasting, and skin-friendly."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Featured Product",
      "info": "Select the real product to showcase in the dynamic hero card."
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Texture/Image",
      "info": "Optional texture or image to overlay on the background."
    },
    {
      "type": "range",
      "id": "bg_image_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 15,
      "label": "Background Image Opacity"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60,
      "label": "Padding Bottom"
    }
  ],
  "presets": [
    {
      "name": "Custom Product Hero"
    }
  ]
}
{% endschema %}
