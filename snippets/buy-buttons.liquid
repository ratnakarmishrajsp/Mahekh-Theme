{% comment %}
  Renders product buy-buttons.
  Accepts:
  - product: {Object} product object.
  - block: {Object} passing the block information.
  - product_form_id: {String} product form id.
  - section_id: {String} id of section to which this snippet belongs.
  - show_pickup_availability: {Boolean} for the pickup availability. If true the pickup availability is rendered, false - not rendered (optional).

  Usage:
  {% render 'buy-buttons', block: block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: true %}
{% endcomment %}
<div {{ block.shopify_attributes }}>
  {%- if product != blank -%}
    {%- liquid
      assign gift_card_recipient_feature_active = false
      if block.settings.show_gift_card_recipient and product.gift_card?
        assign gift_card_recipient_feature_active = true
      endif

      assign show_dynamic_checkout = false
      if block.settings.show_dynamic_checkout and gift_card_recipient_feature_active == false
        assign show_dynamic_checkout = true
      endif

      assign show_cod_button = true
      if block.settings.show_cod_button == false
        assign show_cod_button = false
      endif
      assign cod_button_text = block.settings.cod_button_text | default: "Order Now - Cash on Delivery"
    -%}

    <product-form
      class="product-form"
      data-hide-errors="{{ gift_card_recipient_feature_active }}"
      data-section-id="{{ section.id }}"
    >
      <div class="product-form__error-message-wrapper" role="alert" hidden>
        <span class="svg-wrapper">
          {{- 'icon-error.svg' | inline_asset_content -}}
        </span>
        <span class="product-form__error-message"></span>
      </div>

      {%- form 'product',
        product,
        id: product_form_id,
        class: 'form',
        novalidate: 'novalidate',
        data-type: 'add-to-cart-form'
      -%}
        <input
          type="hidden"
          name="id"
          value="{{ product.selected_or_first_available_variant.id }}"
          {% if product.selected_or_first_available_variant.available == false
            or quantity_rule_soldout
            or product.selected_or_first_available_variant == null
          %}
            disabled
          {% endif %}
          class="product-variant-id"
        >

        {%- if gift_card_recipient_feature_active -%}
          {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
        {%- endif -%}

        <div class="product-form__buttons">
          {%- liquid
            assign check_against_inventory = true
            if product.selected_or_first_available_variant.inventory_management != 'shopify' or product.selected_or_first_available_variant.inventory_policy == 'continue'
              assign check_against_inventory = false
            endif
            if product.selected_or_first_available_variant.quantity_rule.min > product.selected_or_first_available_variant.inventory_quantity and check_against_inventory
              assign quantity_rule_soldout = true
            endif
          -%}
          <button
            id="ProductSubmitButton-{{ section_id }}"
            type="submit"
            name="add"
            class="product-form__submit button button--full-width {% if show_dynamic_checkout %}button--secondary{% else %}button--primary{% endif %}"
            {% if product.selected_or_first_available_variant.available == false
              or quantity_rule_soldout
              or product.selected_or_first_available_variant == null
            %}
              disabled
            {% endif %}
          >
            <span>
              {%- if product.selected_or_first_available_variant == null -%}
                {{ 'products.product.unavailable' | t }}
              {%- elsif product.selected_or_first_available_variant.available == false or quantity_rule_soldout -%}
                {{ 'products.product.sold_out' | t }}
              {%- else -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- endif -%}
            </span>
            {%- render 'loading-spinner' -%}
          </button>
          {%- if show_dynamic_checkout -%}
            <input type="hidden" value="true" id="fastrrCollectionPage" />
<input type="hidden" value={{ product.url }} name="productUrl" />
            {{ form | payment_button }}
          {%- endif -%}

          {%- if show_cod_button -%}
            <!-- Vibrant Cash on Delivery (COD) Button with pulsing conversion animation -->
            <!-- This uses official Releasit placeholder classes so the app replaces it in-place directly below Buy Now button -->
            <button
              type="button"
              class="product-form__submit button button--full-width button--primary custom-cod-button-releasit _rsi-cod-form-gempages-button-overwrite _rsi-cod-form-is-gempage"
              style="margin-top: 1rem; margin-bottom: 0.5rem; background: linear-gradient(135deg, #11998e, #38ef7d) !important; color: #ffffff !important; border: none !important; font-weight: 700; font-size: 1.5rem; text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; justify-content: center; gap: 0.8rem; box-shadow: 0 4px 15px rgba(25, 135, 84, 0.25); transition: all 0.3s ease; height: auto; min-height: 48px; border-radius: 4px; padding: 1.2rem 2.5rem; position: relative; overflow: hidden; cursor: pointer; animation: pulse-scale-cod 2s infinite ease-in-out;"
            >
              <svg class="cod-truck-icon" viewBox="0 0 24 24" width="22" height="22" fill="currentColor" style="vertical-align: middle;">
                <path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm12 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm2-5.5h-3V9h3v4z"/>
              </svg>
              <span>{{ cod_button_text }}</span>
            </button>

            <style>
              /* Hide all native Releasit buttons and app embeds to prevent duplicate buttons and force our custom button layout position */
              .releasit-button, 
              .releasit-cod-button, 
              [class*="releasit-button"]:not(.custom-cod-button-releasit), 
              button[class*="releasit"]:not(.custom-cod-button-releasit),
              iframe[src*="releasit"],
              iframe[src*="releas.it"],
              iframe[class*="releasit"],
              iframe[class*="releas.it"],
              iframe[id*="releasit"],
              iframe[id*="releas.it"],
              iframe[id*="rsi-"],
              iframe[class*="rsi-"],
              .product-app-block-wrapper,
              [class*="releasit-sticky"],
              [id*="releasit-sticky"],
              [class*="releasit_sticky"],
              [id*="releasit_sticky"],
              [class*="releas.it-sticky"],
              [id*="releas.it-sticky"],
              [class*="releas.it_sticky"],
              [id*="releas.it_sticky"],
              .releasit-sticky-button,
              .releasit-sticky-cart,
              .rl-sticky-atc,
              [class*="rsi-sticky"],
              [id*="rsi-sticky"],
              [class*="rsi-cod-sticky"],
              [id*="rsi-cod-sticky"],
              .rsi-sticky-button,
              .rsi-sticky-bar,
              .rsi-sticky-bar-wrapper,
              .rsi-sticky-atc,
              [class*="rsi_sticky"],
              [id*="rsi_sticky"] {
                display: none !important;
                visibility: hidden !important;
                height: 0 !important;
                padding: 0 !important;
                margin: 0 !important;
                opacity: 0 !important;
              }

              @keyframes pulse-scale-cod {
                0%, 100% { transform: scale(1); box-shadow: 0 4px 15px rgba(25, 135, 84, 0.25); }
                50% { transform: scale(1.02); box-shadow: 0 8px 25px rgba(25, 135, 84, 0.45); }
              }
              .custom-cod-button-releasit:hover {
                animation: none !important;
                transform: scale(1.04) !important;
                filter: brightness(1.08) !important;
              }
              .custom-cod-button-releasit:active {
                transform: scale(0.98) !important;
              }
            </style>

            <script>
              (function() {
                // Safety Fallback: If Releasit script is not loaded or doesn't replace the button within 2.5 seconds,
                // we force display the button and attach a standard form submit click handler.
                setTimeout(function() {
                  const codBtn = document.querySelector('.custom-cod-button-releasit');
                  if (codBtn) {
                    const isReplaced = codBtn.classList.contains('rsi-button-replaced') || 
                                       codBtn.closest('.rsi-replaced') || 
                                       document.querySelector('.releasit-button-replaced');
                    
                    // If not replaced and is hidden by the app's stylesheet, restore visibility and add fallback form submit
                    if (!isReplaced && (codBtn.offsetHeight === 0 || window.getComputedStyle(codBtn).display === 'none')) {
                      codBtn.classList.remove('_rsi-cod-form-gempages-button-overwrite', '_rsi-cod-form-is-gempage');
                      codBtn.style.setProperty('display', 'flex', 'important');
                      codBtn.style.setProperty('visibility', 'visible', 'important');
                      codBtn.style.setProperty('opacity', '1', 'important');
                      
                      codBtn.addEventListener('click', function(e) {
                        const form = codBtn.closest('form');
                        if (form) {
                          e.preventDefault();
                          form.submit();
                        }
                      });
                    }
                  }
                }, 2500);

                // Anti-Sticky Button Blocker: Monitor the DOM and block any fixed/sticky buttons
                // containing Cash on Delivery or COD text (excluding our custom checkout button).
                function blockStickyCodButtons() {
                  const elements = document.querySelectorAll('div, button, a, iframe');
                  elements.forEach(function(el) {
                    // Check if it's our own custom button or inside standard theme sections (do not block)
                    if (el.classList.contains('custom-cod-button-releasit') || el.classList.contains('prepaid-checkout-btn-releasit') || el.classList.contains('fallback-checkout-btn-releasit')) return;
                    if (el.closest('.shopify-section') || el.closest('#MainContent') || el.closest('header') || el.closest('footer')) return;
                    
                    // Check if the element contains COD/Order Now text
                    const text = el.innerText || el.textContent || '';
                    const isCodRelated = text.includes('Cash on Delivery') || 
                                         text.includes('COD') || 
                                         text.includes('Order Now') || 
                                         text.includes('Order now') ||
                                         text.includes('Cash On Delivery') ||
                                         text.includes('delivery') ||
                                         text.includes('Delivery') ||
                                         text.includes('cash');
                    
                    // Check if the element's style is sticky or fixed
                    const style = window.getComputedStyle(el);
                    const isStickyOrFixed = style.position === 'fixed' || style.position === 'sticky';
                    
                    if (isStickyOrFixed && isCodRelated) {
                      el.style.setProperty('display', 'none', 'important');
                      el.style.setProperty('visibility', 'hidden', 'important');
                      el.style.setProperty('opacity', '0', 'important');
                      el.style.setProperty('height', '0', 'important');
                      el.style.setProperty('pointer-events', 'none', 'important');
                    }
                  });
                }

                // Helper to search recursively inside a DOM root including Shadow DOMs
                function findButtonInDOM(root) {
                  if (!root) return null;
                  
                  // Check current root's buttons
                  const buttons = root.querySelectorAll('button, input[type="button"], input[type="submit"], [role="button"], a.btn, div[class*="btn"], div[class*="button"]');
                  for (let btn of buttons) {
                    if (btn.classList.contains('custom-cod-button-releasit') || btn.classList.contains('prepaid-checkout-btn-releasit')) continue;
                    if (btn.id && (btn.id.includes('ProductSubmitButton') || btn.id.includes('SubmitButton'))) continue;
                    if (btn.name === 'add' || btn.classList.contains('product-form__submit')) continue;

                    const text = btn.innerText || btn.textContent || '';
                    const isReleasitBtn = text.includes('Complete') || 
                                         text.includes('Place') || 
                                         text.includes('Confirm') || 
                                         (text.includes('Order') && (text.includes('₹') || text.includes('Rs.') || text.includes('1299') || text.includes('price')));
                    
                    if (isReleasitBtn) {
                      return btn;
                    }
                  }

                  // Recursively check all child elements for shadow roots
                  const allElements = root.querySelectorAll('*');
                  for (let el of allElements) {
                    if (el.shadowRoot) {
                      const found = findButtonInDOM(el.shadowRoot);
                      if (found) return found;
                    }
                  }

                  return null;
                }

                // Search same-origin iframes recursively
                function findReleasitSubmitButton() {
                  let btn = findButtonInDOM(document);
                  if (btn) return btn;

                  const iframes = document.querySelectorAll('iframe');
                  for (let iframe of iframes) {
                    try {
                      if (iframe.contentDocument) {
                        btn = findButtonInDOM(iframe.contentDocument);
                        if (btn) return btn;
                      }
                    } catch (e) {
                      // Cross-origin iframe, ignore
                    }
                  }
                  return null;
                }

                // Central function to query all possible Releasit elements in the DOM
                function getReleasitElements() {
                  const elements = document.querySelectorAll('div[class*="releasit"], div[id*="releasit"], div[class*="releas.it"], div[id*="releas.it"], [class*="rsi-"], [id*="rsi-"], .rsi-modal, #releasit-modal, iframe[src*="releasit"], iframe[src*="releas.it"], iframe[class*="releasit"], iframe[class*="releas.it"], iframe[id*="releasit"], iframe[id*="releas.it"], iframe[id*="rsi-"], iframe[class*="rsi-"]');
                  return Array.from(elements).filter(function(el) {
                    return !el.classList.contains('custom-cod-button-releasit') && 
                           !el.classList.contains('custom-prepaid-fallback-releasit') && 
                           !el.classList.contains('custom-prepaid-promo-releasit') &&
                           !el.classList.contains('prepaid-checkout-btn-releasit') &&
                           !el.classList.contains('fallback-checkout-btn-releasit');
                  });
                }

                // Check if any Releasit iframe or modal element is currently visible
                function isReleasitModalVisible() {
                  const releasitElements = getReleasitElements();
                  for (let el of releasitElements) {
                    const style = window.getComputedStyle(el);
                    if (style.display !== 'none' && style.visibility !== 'hidden' && el.offsetHeight > 0) {
                      return el;
                    }
                  }
                  return null;
                }

                // Trigger standard prepaid checkout on parent page
                function triggerPrepaidCheckout() {
                  const productForm = document.querySelector('form[action="/cart/add"], #product-form-{{ section_id }}');
                  if (productForm) {
                    const checkoutBtn = productForm.querySelector('button[type="submit"], .product-form__submit');
                    if (checkoutBtn) {
                      checkoutBtn.click();
                    } else {
                      productForm.submit();
                    }
                  }
                }

                // Fallback banner for cross-origin iframes
                function showPrepaidFallbackBanner() {
                  let fallback = document.querySelector('.custom-prepaid-fallback-releasit');
                  let currentPrice = {{ product.selected_or_first_available_variant.price | divided_by: 100 }};
                  const prepaidPrice = currentPrice - 100;

                  if (!fallback) {
                    fallback = document.createElement('div');
                    fallback.className = 'custom-prepaid-fallback-releasit';
                    fallback.style.cssText = 'position: fixed; bottom: 0; left: 0; right: 0; background: #ffffff !important; box-shadow: 0 -4px 20px rgba(0,0,0,0.15); padding: 1.2rem 1.5rem; z-index: 2147483647; text-align: center; border-top: 3px solid #cca43b; box-sizing: border-box; display: block; animation: slideUp 0.3s ease-out;';
                    fallback.innerHTML = `
                      <div style="max-width: 500px; margin: 0 auto; display: flex; flex-direction: column; gap: 0.8rem; font-family: inherit;">
                        <p style="margin: 0; font-size: 1.3rem; color: #1e293b; font-weight: 700; line-height: 1.3;">
                          💡 Want to pay online? Get it for just <span style="color: #cca43b; font-size: 1.45rem;">₹${prepaidPrice}</span> (Save ₹100 Instantly!)
                        </p>
                        <button type="button" class="fallback-checkout-btn-releasit" style="width: 100%; padding: 1.1rem; background: linear-gradient(135deg, #cca43b, #a3802e) !important; color: #ffffff !important; border: none !important; border-radius: 4px; font-weight: 700; font-size: 1.3rem; text-transform: uppercase; letter-spacing: 0.05em; cursor: pointer; box-shadow: 0 2px 8px rgba(204, 164, 59, 0.2); font-family: inherit;">
                          💳 Pay Online - ₹${prepaidPrice}
                        </button>
                      </div>
                      <style>
                        @keyframes slideUp {
                          from { transform: translateY(100%); }
                          to { transform: translateY(0); }
                        }
                      </style>
                    `;
                    document.body.appendChild(fallback);

                    const fallbackBtn = fallback.querySelector('.fallback-checkout-btn-releasit');
                    if (fallbackBtn) {
                      fallbackBtn.addEventListener('click', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        
                        // Close Releasit modal/iframe
                        const releasitElements = getReleasitElements();
                        releasitElements.forEach(function(el) {
                          if (el.classList.contains('custom-prepaid-fallback-releasit')) return;
                          const closeBtn = el.querySelector('button[class*="close"], span[class*="close"], [class*="close-icon"], .close, #close');
                          if (closeBtn) {
                            closeBtn.click();
                          } else {
                            el.style.setProperty('display', 'none', 'important');
                          }
                        });

                        fallback.style.setProperty('display', 'none', 'important');
                        triggerPrepaidCheckout();
                      });
                    }
                  } else {
                    fallback.style.setProperty('display', 'block', 'important');
                    // Dynamically update price in case variant changed
                    const priceSpan = fallback.querySelector('span');
                    if (priceSpan && priceSpan.innerText !== '₹' + prepaidPrice) {
                      priceSpan.innerText = '₹' + prepaidPrice;
                      const btn = fallback.querySelector('.fallback-checkout-btn-releasit');
                      if (btn) btn.innerText = '💳 Pay Online - ₹' + prepaidPrice;
                    }
                  }
                }

                // Monitor for Releasit COD modal opening to inject the Prepaid Discount Promo
                function checkReleasitModal() {
                  const btn = findReleasitSubmitButton();
                  
                  if (btn) {
                    // Hide the fallback sticky bar if it was showing
                    const fallback = document.querySelector('.custom-prepaid-fallback-releasit');
                    if (fallback) fallback.style.setProperty('display', 'none', 'important');

                    // Avoid double injection next to the button
                    const parent = btn.parentNode;
                    if (!parent || parent.querySelector('.custom-prepaid-promo-releasit')) return;

                    const text = btn.innerText || btn.textContent || '';
                    let currentPrice = {{ product.selected_or_first_available_variant.price | divided_by: 100 }};
                    const priceMatch = text.match(/(?:Rs\.?|₹|INR)\s*([\d,]+)/i);
                    if (priceMatch) {
                      currentPrice = parseInt(priceMatch[1].replace(/,/g, ''));
                    }
                    const prepaidPrice = currentPrice - 100;

                    // Create the prepaid promo element
                    const promoDiv = document.createElement('div');
                    promoDiv.className = 'custom-prepaid-promo-releasit';
                    promoDiv.style.cssText = 'margin-top: 1.2rem; padding: 1.2rem 1rem 0 1rem; border-top: 1px dashed #e2e8f0; text-align: center; width: 100%; box-sizing: border-box; display: block !important;';
                    promoDiv.innerHTML = `
                      <p style="margin: 0 0 0.8rem 0; font-size: 1.3rem; color: #475569; font-weight: 600; line-height: 1.4; font-family: inherit;">
                        💡 Prepay online and get it for just <strong style="color: #cca43b; font-size: 1.45rem;"><span class="prepaid-price-val">₹${prepaidPrice}</span></strong> (Save ₹100 Instantly!)
                      </p>
                      <button type="button" class="prepaid-checkout-btn-releasit" style="width: 100%; padding: 1.1rem; background: linear-gradient(135deg, #cca43b, #a3802e) !important; color: #ffffff !important; border: none !important; border-radius: 4px; font-weight: 700; font-size: 1.3rem; text-transform: uppercase; letter-spacing: 0.05em; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 0.5rem; transition: all 0.3s ease; box-shadow: 0 2px 8px rgba(204, 164, 59, 0.2); font-family: inherit;">
                        💳 Pay Online - <span class="prepaid-btn-val">₹${prepaidPrice}</span>
                      </button>
                    `;

                    btn.parentNode.insertBefore(promoDiv, btn.nextSibling);

                    const prepayBtn = promoDiv.querySelector('.prepaid-checkout-btn-releasit');
                    if (prepayBtn) {
                      prepayBtn.addEventListener('click', function(e) {
                        e.preventDefault();
                        e.stopPropagation();
                        
                        // Close Releasit modal
                        const modal = btn.closest('div[class*="modal"], div[id*="modal"], div[class*="popup"], div[id*="popup"], div[class*="releasit"], div[id*="releasit"], div[class*="releas.it"], div[id*="releas.it"], div[class*="rsi-"], div[id*="rsi-"]');
                        if (modal) {
                          const closeBtn = modal.querySelector('button[class*="close"], span[class*="close"], [class*="close-icon"], .close, #close');
                          if (closeBtn) {
                            closeBtn.click();
                          } else {
                            modal.style.setProperty('display', 'none', 'important');
                          }
                        }

                        triggerPrepaidCheckout();
                      });
                    }
                  } else {
                    // Check if the Releasit modal or iframe is visible
                    const activeModal = isReleasitModalVisible();
                    if (activeModal) {
                      showPrepaidFallbackBanner();
                    } else {
                      // Hide fallback banner if Releasit modal is closed
                      const fallback = document.querySelector('.custom-prepaid-fallback-releasit');
                      if (fallback) fallback.style.setProperty('display', 'none', 'important');
                    }
                  }
                }

                // Safely run DOM actions without causing infinite MutationObserver loops
                let observer = null;
                function runObserverActions() {
                  if (observer) {
                    observer.disconnect(); // Temporary disconnect to avoid infinite self-trigger loops
                  }
                  
                  blockStickyCodButtons();
                  checkReleasitModal();
                  
                  if (observer && window.MutationObserver) {
                    observer.observe(document.documentElement, { childList: true, subtree: true });
                  }
                }

                // Attach event listeners for scroll, load and resize events to continuously block
                window.addEventListener('scroll', runObserverActions, { passive: true });
                window.addEventListener('resize', runObserverActions, { passive: true });
                window.addEventListener('load', runObserverActions);

                // Use MutationObserver to instantly hide duplicate buttons and inject promo
                if (window.MutationObserver) {
                  observer = new MutationObserver(runObserverActions);
                  observer.observe(document.documentElement, { childList: true, subtree: true });
                }

                // Initial run
                runObserverActions();
              })();
            </script>
          {%- endif -%}
        </div>
      {%- endform -%}
    </product-form>

    <div class="custom-pdp-trust-strip" style="margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.8rem; padding: 1.2rem; background: #faf8f5; border: 1px solid rgba(204, 164, 59, 0.25); border-radius: 8px;">
      <div style="display: flex; align-items: center; gap: 0.8rem; font-size: 1.3rem; font-weight: 600; color: #121212;">
        <span style="font-size: 1.5rem;">💵</span> 100% Cash on Delivery (COD) Available
      </div>
      <div style="display: flex; align-items: center; gap: 0.8rem; font-size: 1.3rem; font-weight: 600; color: #121212;">
        <span style="font-size: 1.5rem;">🌿</span> 100% Pure & Alcohol-Free (Skin Safe)
      </div>
      <div style="display: flex; align-items: center; gap: 0.8rem; font-size: 1.3rem; font-weight: 600; color: #121212;">
        <span style="font-size: 1.5rem;">🚚</span> Free Express Delivery Across India (3-5 Days)
      </div>
    </div>
  {%- else -%}
    <div class="product-form">
      <div class="product-form__buttons form">
        <button
          type="submit"
          name="add"
          class="product-form__submit button button--full-width button--primary"
          disabled
        >
          {{ 'products.product.sold_out' | t }}
        </button>
      </div>
    </div>
  {%- endif -%}

  {%- if show_pickup_availability -%}
    {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}

    {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities
      | where: 'pick_up_enabled', true
    -%}

    <pickup-availability
      class="product__pickup-availabilities quick-add-hidden"
      {% if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %}
        available
      {% endif %}
      data-root-url="{{ routes.root_url }}"
      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
      data-has-only-default-variant="{{ product.has_only_default_variant }}"
      data-product-page-color-scheme="gradient color-{{ section.settings.color_scheme }}"
    >
      <template>
        <pickup-availability-preview class="pickup-availability-preview">
