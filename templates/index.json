    "custom_faq_homepage": {
      "type": "custom-faq",
      "settings": {
        "title": "Frequently Asked Questions",
        "heading_size": "h1",
        "subtitle": "HAVE QUESTIONS?",
        "content_width": 800,
        "open_first": true,
        "color_scheme": "scheme-1",
        "padding_top": 40,
        "padding_bottom": 40
      },
      "blocks": {
        "faq_1": {
          "type": "faq",
          "settings": {
            "question": "How should I apply concentrated attar oil?",
            "answer": "<p>Apply a few drops of attar to your pulse points, such as your wrists, behind the ears, and inner elbows. Gently dab the oil on the skin without rubbing too vigorously. Rubbing can break down the fragrance molecules.<\/p>"
          }
        },
        "faq_2": {
          "type": "faq",
          "settings": {
            "question": "Is it safe to apply attar on clothes?",
            "answer": "<p>Attar contains pure essential oils, so applying it directly to light-colored or delicate clothing can sometimes leave a faint oil stain. We recommend applying it on pulse points. If you want to use it on clothes, apply a small amount to the inner seams or use it on dark fabrics.<\/p>"
          }
        },
        "faq_3": {
          "type": "faq",
          "settings": {
            "question": "How long does Mahekh attar last?",
            "answer": "<p>Due to its high concentration of pure oils and traditional steam distillation process, our attars typically last between 8 to 12 hours on skin, and even longer on fabric. The exact duration depends on the specific note profile (e.g., Oudh and Amber profiles last longer than light Floral profiles).<\/p>"
          }
        }
      },
      "block_order": [
        "faq_1",
        "faq_2",
        "faq_3"
      ]
