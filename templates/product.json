        "collapsible_tab_kannauj": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "The Kannauj Heritage",
            "icon": "leaf",
            "content": "<p>Each drop of Mahekh attar is distilled using traditional copper pots (Degs) and clay receivers (Bhapkas) in Kannauj, the perfume capital of India. We source only the purest natural blossoms and ingredients.<\/p>"
